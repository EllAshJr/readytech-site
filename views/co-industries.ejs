<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="co-industries-page">
      <section class="hero">
        <div class="container">
          <span class="brand-mark brand-mark-readytech hero-mark" aria-hidden="true">RT</span>
          <p class="eyebrow">ReadyTech Co-Industries</p>
          <h1><%= coIndustries.parent.headline %></h1>
          <p><%= coIndustries.parent.description %></p>

          <div class="hero-actions">
            <a href="/ready-kitchen-exhaust" class="button industry-button industry-button-kitchen" data-track-lead="co-industries-kitchen">
              Visit Ready Kitchen Exhaust
            </a>
            <a href="/ready-hydro-vac" class="button industry-button industry-button-hydro" data-track-lead="co-industries-hydro">
              Visit Ready Hydro-Vac
            </a>
          </div>
        </div>
      </section>

      <section class="container section">
        <p class="eyebrow">Why this belongs here</p>
        <h2>ReadyTech stays focused while customers get a trusted path to adjacent services.</h2>
        <p class="lead"><%= coIndustries.parent.positioning %></p>
      </section>

      <section class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">
            <%= currentBusiness ? "Related heavy duty services" : "Choose a path" %>
          </p>
          <h2>
            <%= currentBusiness ? "Need one of the connected services?" : "Start with the business that matches the job." %>
          </h2>
          <div class="co-industry-action-row">
            <% relatedBusinesses.forEach(function (business) { %>
              <a href="/<%= business.slug %>" class="mini-link co-industry-mini-link co-industry-theme-<%= business.theme %>" data-track-lead="co-industry-related-<%= business.id %>">
                <span class="brand-mark brand-mark-<%= business.theme %> mini-mark" aria-hidden="true"><%= business.mark %></span>
                <span><%= business.shortName %></span>
              </a>
            <% }); %>
            <a href="https://readytechinstalls.com" class="mini-link co-industry-mini-link co-industry-theme-readytech" data-track-lead="co-industry-related-readytech">
              <span class="brand-mark brand-mark-readytech mini-mark" aria-hidden="true">RT</span>
              <span>ReadyTech</span>
            </a>
          </div>
        </article>
      </section>

      <section class="container section">
        <p class="eyebrow">Heavy duty services</p>
        <h2>Support for kitchens, job sites, contractors, and commercial operators.</h2>

        <div class="grid co-industry-card-grid">
          <% coIndustries.businesses.forEach(function (business) { %>
            <article class="card co-industry-card co-industry-tile co-industry-theme-<%= business.theme %>">
              <span class="brand-mark brand-mark-<%= business.theme %>" aria-hidden="true"><%= business.mark %></span>
              <p class="eyebrow"><%= business.category %></p>
              <h3><%= business.name %></h3>
              <p><%= business.byline %></p>
              <p><%= business.shortDescription %></p>

              <ul>
                <% business.serviceAreas.forEach(function (area) { %>
                  <li><%= area %></li>
                <% }); %>
              </ul>

              <div class="hero-actions">
                <a href="/<%= business.slug %>" class="button industry-button industry-button-<%= business.theme %>" data-track-lead="co-industry-visit-<%= business.id %>">
                  Visit Site
                </a>
                <a href="/<%= business.slug %>/contact" class="button industry-button industry-button-<%= business.theme %> industry-button-outline" data-track-lead="co-industry-contact-<%= business.id %>">
                  Request Quote
                </a>
              </div>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">ReadyTech boundary</p>
          <h2>Technology remains ReadyTech's core lane.</h2>
          <p>
            ReadyTech continues to focus on business uptime, managed
            connectivity, monitoring, backup internet, business Wi-Fi, and
            restaurant technology. These co-industry links are a practical way
            to connect local operators with related heavy-duty service brands.
          </p>
          <a href="/contact?service=co-industries" class="button secondary" data-track-lead="co-industries-readytech-question">
            Ask ReadyTech a Question
          </a>
        </article>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
