# Local development only. Never commit a real .env file.
NODE_ENV=development
BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=false
DATABASE_POOL_MAX=5

# Resend transactional email
RESEND_API_KEY=re_replace_me
OWNER_EMAIL=owner@example.com
QUOTE_FROM_EMAIL=ReadyTech Estimates <quotes@updates.readytechinstalls.com>
QUOTE_REPLY_TO=contact@readytechinstalls.com

# Secure estimate decision links
QUOTE_TOKEN_SECRET=replace_with_at_least_32_random_bytes

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me
TURNSTILE_EXPECTED_HOSTNAME=readytechinstalls.com
