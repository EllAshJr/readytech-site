<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main>
      <section class="hero">
        <div class="container">
          <p class="eyebrow"><%= siteStrategy.brand.category %></p>
          <h1><%= siteStrategy.brand.hero %></h1>
          <p><%= siteStrategy.brand.positioning %></p>

          <div class="hero-actions">
            <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
              <%= siteStrategy.ctas.primary.label %>
            </a>

            <a href="<%= siteStrategy.ctas.secondary.href %>" class="button secondary">
              <%= siteStrategy.ctas.secondary.label %>
            </a>
          </div>
        </div>
      </section>

      <section class="container section">
        <p class="eyebrow">Three service pillars</p>
        <h2>One operating model for business-critical connectivity</h2>

        <div class="grid">
          <% siteStrategy.pillars.forEach(function (pillar) { %>
            <article class="card">
              <h3><%= pillar.title %></h3>
              <p><strong><%= pillar.outcome %></strong></p>
              <p><%= pillar.description %></p>

              <ul>
                <% pillar.links.forEach(function (service) { %>
                  <li>
                    <a href="<%= service.href %>"><%= service.label %></a>
                  </li>
                <% }); %>
              </ul>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <p class="eyebrow">Flagship offers</p>
        <h2>Start with the right level of protection</h2>

        <div class="pricing-grid flagship-offers-grid">
          <% siteStrategy.flagshipOffers.forEach(function (offer) { %>
            <article class="price-card<%= offer.featured ? " flagship-featured" : "" %>">
              <h3><%= offer.title %></h3>
              <p class="price"><%= offer.price %></p>
              <p><%= offer.priceNote %></p>
              <p><%= offer.description %></p>

              <ul>
                <% offer.includes.forEach(function (item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <% if (offer.note) { %>
                <p><small><%= offer.note %></small></p>
              <% } %>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section trust-section">
        <p class="eyebrow">Why local businesses trust ReadyTech</p>
        <h2>Practical work, documented clearly, built for uptime.</h2>

        <div class="grid">
          <% siteStrategy.trustSignals.forEach(function (signal) { %>
            <article class="card compact-card">
              <h3><%= signal.title %></h3>
              <p><%= signal.description %></p>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <p class="eyebrow">Example jobs</p>
        <h2>Common problems ReadyTech helps solve</h2>

        <div class="grid case-study-grid">
          <% siteStrategy.exampleJobs.forEach(function (job) { %>
            <article class="card compact-card">
              <p class="eyebrow"><%= job.business %></p>
              <h3><%= job.title %></h3>
              <p><%= job.problem %></p>
            </article>
          <% }); %>
        </div>

        <div class="hero-actions">
          <a href="/case-studies" class="button secondary" data-track-lead="home-examples">
            View Example Jobs
          </a>
        </div>
      </section>

      <section class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">Restaurant specialization</p>
          <h2><%= siteStrategy.restaurantAddOn.title %></h2>
          <p class="price"><%= siteStrategy.restaurantAddOn.price %></p>
          <p><%= siteStrategy.restaurantAddOn.description %></p>
          <p><%= siteStrategy.restaurantAddOn.typicalTotal %></p>

          <a href="/services/restaurant-technology" class="button">
            Explore Restaurant Services
          </a>
        </article>
      </section>

      <section id="service-areas" class="container section">
        <p class="eyebrow">Service areas</p>
        <h2>Onsite where we are strongest. Scheduled support where we extend.</h2>

        <div class="grid">
          <% siteStrategy.serviceAreas.forEach(function (area) { %>
            <article class="card">
              <h3><%= area.title %></h3>
              <p><strong><%= area.type %></strong></p>
              <p><%= area.description %></p>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section faq-section">
        <p class="eyebrow">FAQ</p>
        <h2>Quick answers before you book</h2>

        <div class="faq-list">
          <% siteStrategy.faqs.forEach(function (faq) { %>
            <details class="faq-item">
              <summary><%= faq.question %></summary>
              <p><%= faq.answer %></p>
            </details>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <article class="card">
          <p class="eyebrow">Built for local operators</p>
          <h2>Restaurant-led, but not restaurant-only</h2>
          <p>
            ReadyTech is built for independent restaurants, fast-casual
            operators, retailers, and service businesses with one to five
            locations and no internal IT department.
          </p>
          <p><strong><%= siteStrategy.brand.tagline %></strong></p>
        </article>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
