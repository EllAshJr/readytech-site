<!DOCTYPE html>
<html lang="en">
  <%- include("partials/co-industry-head") %>

  <body class="co-industry-site co-industry-theme-<%= business.theme %>">
    <%- include("partials/co-industry-header") %>

    <%
      const formValues = typeof values === "object" && values ? values : {};
      const valueOf = (name, fallback = "") =>
        formValues[name] !== undefined ? formValues[name] : fallback;
      const noticeMessage = typeof notice === "string" ? notice : "";
      const errorMessage = typeof error === "string" ? error : "";
    %>

    <main class="container section">
      <span class="brand-mark brand-mark-<%= business.theme %>" aria-hidden="true"><%= business.mark %></span>
      <p class="eyebrow"><%= business.shortName %></p>
      <h1><%= business.primaryCta %></h1>
      <p class="lead">
        Tell the team what you need, where the job is located, and how urgent it
        is. You can also call <a href="<%= business.phoneHref %>"><%= business.phone %></a>.
      </p>

      <% if (noticeMessage) { %>
        <div class="site-notice" role="status"><%= noticeMessage %></div>
      <% } %>

      <% if (errorMessage) { %>
        <div class="quote-errors" role="alert">
          <h2>We could not send that request</h2>
          <p><%= errorMessage %></p>
        </div>
      <% } %>

      <form action="<%= links.contact %>" method="POST" class="contact-form co-industry-contact-form">
        <label>
          Name
          <input type="text" name="name" value="<%= valueOf('name') %>" maxlength="160" required />
        </label>

        <label>
          Email
          <input type="email" name="email" value="<%= valueOf('email') %>" maxlength="320" required />
        </label>

        <label>
          Phone
          <input type="tel" name="phone" value="<%= valueOf('phone') %>" maxlength="80" />
        </label>

        <label>
          City / job location
          <input type="text" name="city" value="<%= valueOf('city') %>" maxlength="160" />
        </label>

        <label>
          Service needed
          <select name="service">
            <option value="">Select one</option>
            <% business.contactServices.forEach(function (service) { %>
              <option value="<%= service %>" <%= valueOf("service") === service ? "selected" : "" %>><%= service %></option>
            <% }); %>
          </select>
        </label>

        <label>
          What do you need?
          <textarea name="message" rows="6" maxlength="2400" required><%= valueOf('message') %></textarea>
        </label>

        <button type="submit" class="button"><%= business.primaryCta %></button>
      </form>
    </main>

    <%- include("partials/co-industry-footer") %>
  </body>
</html>
