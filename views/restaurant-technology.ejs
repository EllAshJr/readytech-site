<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="restaurant-page">
      <section class="hero">
        <div class="container">
          <p class="eyebrow">ReadyOps for Restaurants</p>

          <h1>Restaurant Network, POS & Uptime Support</h1>

          <p>
            Restaurants are ReadyTech’s first specialization—not its only
            market. We help restaurant operators keep POS, payments, Wi-Fi,
            online orders, printers, kitchen systems, and internet connectivity
            operating reliably.
          </p>

          <div class="hero-actions">
            <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
              Book a Business Uptime Assessment
            </a>

            <a
              href="/instant-quote?service=restaurant-technology"
              class="button secondary"
            >
              Get a Restaurant Estimate
            </a>
          </div>
        </div>
      </section>

      <section class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">Managed restaurant operations</p>

          <h2><%= siteStrategy.restaurantAddOn.title %></h2>

          <p class="price"><%= siteStrategy.restaurantAddOn.price %></p>

          <p><%= siteStrategy.restaurantAddOn.description %></p>

          <ul>
            <% siteStrategy.restaurantAddOn.includes.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <p>
            <strong><%= siteStrategy.restaurantAddOn.typicalTotal %></strong>
          </p>
        </article>
      </section>

      <section class="container section">
        <h2>Core Restaurant Infrastructure</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.coreServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>POS, Menus & Delivery Operations</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.operationsServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Customer Experience & Retention</h2>

        <div
          class="grid restaurant-wide-grid restaurant-no-scroll-grid customer-experience-grid"
        >
          <% restaurantData.customerExperienceServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Restaurant Monitoring</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.monitoringServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Monitored Items</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Restaurant Technology Packages</h2>

        <div class="pricing-grid">
          <% restaurantData.packages.forEach(function(pkg) { %>
            <article class="price-card">
              <h3><%= pkg.name %></h3>

              <p><%= pkg.description %></p>

              <p>
                <strong>Setup:</strong>
                <%= pkg.setup %>
              </p>

              <p>
                <strong>Monthly:</strong>
                <%= pkg.monthly %>
              </p>

              <ul>
                <% pkg.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>
            </article>
          <% }); %>
        </div>
      </section>

      <section id="health-check" class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">Recommended first step</p>

          <h2><%= siteStrategy.flagshipOffers[0].title %></h2>

          <p class="price"><%= siteStrategy.flagshipOffers[0].price %></p>

          <p><%= siteStrategy.flagshipOffers[0].description %></p>

          <h3>Inspection Areas</h3>

          <ul class="columns">
            <% restaurantData.healthCheck.inspect.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <h3>Report Sections</h3>

          <ul class="columns">
            <% restaurantData.healthCheck.reportSections.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <% if (siteStrategy.flagshipOffers[0].note) { %>
            <p>
              <small><%= siteStrategy.flagshipOffers[0].note %></small>
            </p>
          <% } %>

          <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
            Book the Assessment
          </a>
        </article>
      </section>

      <section class="container section">
        <h2>Restaurant Service Pages</h2>

        <p>
          Explore specific restaurant connectivity and operations services
          available for businesses in Austin, Manor, and Houston.
        </p>

        <div class="link-grid">
          <% Object.keys(restaurantData.seoServices).forEach(function(slug) { %>
            <a href="/services/<%= slug %>" class="mini-link">
              <%= restaurantData.seoServices[slug].title %>
            </a>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <p class="service-note"><%= siteStrategy.pricingNotice %></p>

        <div class="hero-actions">
          <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
            Book a Business Uptime Assessment
          </a>

          <a
            href="/instant-quote?service=restaurant-technology"
            class="button secondary"
          >
            Get an Instant Estimate
          </a>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
EOF

  node - <<'NODE'
const fs = require("fs");
const ejs = require("ejs");

const file = "views/restaurant-technology.ejs";

try {
  const template = fs.readFileSync(file, "utf8");

  ejs.compile(template, {
    filename: file,
  });

  console.log("EJS syntax passed:", file);
} catch (error) {
  console.error("EJS syntax failed:", file);
  console.error(error.message);
  process.exit(1);
}
NODE

  grep -n \
    "ReadyOps for Restaurants\|Restaurant Operations Add-on\|Book a Business Uptime Assessment" \
    views/restaurant-technology.ejs

  echo
  echo "STEP 10 COMPLETE"
  echo "Backup saved in: backups/strategy-$STAMP"
)
