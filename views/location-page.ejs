<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="container section">
      <p class="eyebrow">Local Private Infrastructure Support</p>
      <h1><%= location.title %></h1>

      <p><%= location.description %></p>

      <section>
        <h2>Services Available in <%= location.city %></h2>

        <div class="grid">
          <% Object.keys(services).forEach(function(slug) { %>
            <article class="card">
              <h3><%= services[slug].title %> in <%= location.city %></h3>
              <p><%= services[slug].description %></p>
              <a href="/services/<%= slug %>">View service</a>
            </article>
          <% }) %>
        </div>
      </section>

      <% if (localSeoPages && localSeoPages.length) { %>
        <section class="section">
          <p class="eyebrow">Focused local services</p>
          <h2>Popular ReadyTech help in <%= location.city %></h2>

          <div class="grid">
            <% localSeoPages.forEach(function(localPage) { %>
              <article class="card compact-card">
                <h3><%= localPage.title %></h3>
                <p><%= localPage.description %></p>
                <a href="/locations/<%= localPage.city %>/<%= localPage.slug %>">
                  View local service
                </a>
              </article>
            <% }); %>
          </div>
        </section>
      <% } %>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
