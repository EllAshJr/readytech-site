<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>

  <body>
    <%- include("../partials/header") %>

    <main class="container section quote-page">
      <p class="eyebrow">ReadyTech Instant Estimate</p>
      <h1>Review your estimate</h1>
      <p class="lead">
        Review the assumptions and estimated costs below. ReadyTech recalculates the estimate on the server before saving it.
      </p>

      <% if (typeof errors !== "undefined" && errors && errors.length) { %>
        <div class="quote-errors" role="alert">
          <ul><% errors.forEach(function(error) { %><li><%= error %></li><% }); %></ul>
        </div>
      <% } %>

      <section class="quote-summary-card">
        <div>
          <span>Business</span>
          <strong><%= estimate.input.business_name %></strong>
        </div>
        <div>
          <span>Contact</span>
          <strong><%= estimate.input.customer_name %></strong>
        </div>
        <div>
          <span>Complexity</span>
          <strong><%= estimate.complexityLevel %></strong>
        </div>
        <div>
          <span>Valid through</span>
          <strong><%= new Date(estimate.expiresAt).toLocaleDateString('en-US') %></strong>
        </div>
      </section>

      <section class="quote-estimate-card">
        <div class="quote-total-grid">
          <div>
            <span>Estimated one-time setup</span>
            <strong><%= formatMoney(estimate.setupTotal) %></strong>
          </div>
          <div>
            <span>Estimated monthly service</span>
            <strong><%= formatMoney(estimate.monthlyTotal) %>/month</strong>
          </div>
        </div>

        <div class="table-wrap">
          <table class="pricing-table quote-line-items">
            <thead>
              <tr><th>Service</th><th>Setup</th><th>Monthly</th></tr>
            </thead>
            <tbody>
              <% estimate.lineItems.forEach(function(item) { %>
                <tr>
                  <td>
                    <strong><%= item.name %></strong>
                    <% if (item.notes && item.notes.length) { %>
                      <ul class="quote-line-notes"><% item.notes.forEach(function(note) { %><li><%= note %></li><% }); %></ul>
                    <% } %>
                    <% if (item.manualReview) { %><small class="quote-review-badge">Final review required</small><% } %>
                  </td>
                  <td><%= formatMoney(item.setup) %></td>
                  <td><%= formatMoney(item.monthly) %>/mo</td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>

      <% if (estimate.warnings.length) { %>
        <section class="quote-warning-card">
          <h2>Items requiring verification</h2>
          <ul><% estimate.warnings.forEach(function(warning) { %><li><%= warning %></li><% }); %></ul>
        </section>
      <% } %>

      <section class="quote-assumptions">
        <h2>Assumptions and exclusions</h2>
        <ul><% estimate.assumptions.forEach(function(assumption) { %><li><%= assumption %></li><% }); %></ul>
      </section>

      <form action="/instant-quote/submit" method="POST" class="quote-submit-form">
        <input type="hidden" name="quotePayload" value="<%= quotePayload %>" />

        <% if (turnstileSiteKey) { %>
          <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="dark"></div>
        <% } else { %>
          <p class="quote-help-text">Development mode: Cloudflare Turnstile is not configured.</p>
        <% } %>

        <div class="quote-actions">
          <button type="submit" class="button">Email and Save This Estimate</button>
          <a href="/instant-quote" class="button secondary">Start Over</a>
        </div>
      </form>
    </main>

    <% if (turnstileSiteKey) { %>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <% } %>
    <%- include("../partials/footer") %>
  </body>
</html>
