<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="container section pricing-page">
      <p class="eyebrow">Business uptime pricing</p>
      <h1>Clear starting points. Final scope based on the environment.</h1>

      <p class="service-note"><%= siteStrategy.pricingNotice %></p>

      <div class="pricing-grid">
        <% siteStrategy.flagshipOffers.forEach(function (offer) { %>
          <article class="price-card">
            <h2><%= offer.title %></h2>
            <p class="price"><%= offer.price %></p>
            <p><%= offer.priceNote %></p>
            <p><%= offer.description %></p>

            <ul>
              <% offer.includes.forEach(function (item) { %>
                <li><%= item %></li>
              <% }); %>
            </ul>

            <% if (offer.note) { %>
              <p><small><%= offer.note %></small></p>
            <% } %>
          </article>
        <% }); %>
      </div>

      <section class="section">
        <article class="card featured-panel">
          <h2><%= siteStrategy.restaurantAddOn.title %></h2>
          <p class="price"><%= siteStrategy.restaurantAddOn.price %></p>
          <p><%= siteStrategy.restaurantAddOn.description %></p>

          <ul>
            <% siteStrategy.restaurantAddOn.includes.forEach(function (item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <p><%= siteStrategy.restaurantAddOn.typicalTotal %></p>
        </article>
      </section>

      <section class="section">
        <h2>Additional service rates</h2>

        <table class="pricing-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Starting rate</th>
            </tr>
          </thead>
          <tbody>
            <% siteStrategy.publicRates.forEach(function (rate) { %>
              <tr>
                <td><%= rate.label %></td>
                <td><%= rate.value %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </section>

      <section class="section">
        <div class="hero-actions">
          <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
            <%= siteStrategy.ctas.primary.label %>
          </a>

          <a href="<%= siteStrategy.ctas.secondary.href %>" class="button secondary">
            <%= siteStrategy.ctas.secondary.label %>
          </a>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
