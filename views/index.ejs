<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main>
      <section class="hero">
        <div class="container">
          <p class="eyebrow">Austin • Manor • Houston</p>
          <h1>Private Infrastructure for Homes and Small Businesses</h1>
          <p>
            Managed VPN, private cloud, network monitoring, secure Wi-Fi, and
            backup internet built for businesses that need control, uptime, and
            security.
          </p>
          <div class="hero-actions">
            <a href="/pricing" class="button">View Pricing</a>
            <a href="/contact" class="button secondary">Request Consultation</a>
          </div>
        </div>
      </section>

      <section class="container section">
        <h2>Core Services</h2>

        <div class="grid">
          <article class="card">
            <h3>Managed VPN</h3>
            <p>Secure remote access and site-to-site VPN for offices, home labs, and small businesses.</p>
          </article>

          <article class="card">
            <h3>Private Cloud</h3>
            <p>Private storage, backup, and controlled infrastructure for your business data.</p>
          </article>

          <article class="card">
            <h3>Network Monitoring</h3>
            <p>Monitor internet uptime, firewalls, switches, access points, and business-critical devices.</p>
          </article>

          <article class="card">
            <h3>Backup Internet</h3>
            <p>LTE and 5G failover options to keep your site online during outages.</p>
          </article>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
