<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="container section">
      <p class="eyebrow">Local Private Infrastructure Support</p>
      <h1><%= location.title %></h1>

      <p><%= location.description %></p>

      <section>
        <h2>Services Available in <%= location.city %></h2>

        <div class="grid">
          <% Object.keys(services).forEach(function(slug) { %>
            <article class="card">
              <h3><%= services[slug].title %> in <%= location.city %></h3>
              <p><%= services[slug].description %></p>
              <a href="/services/<%= slug %>">View service</a>
            </article>
          <% }) %>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
