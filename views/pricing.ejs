<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="container section pricing-page">
      <p class="eyebrow">ReadyTech Pricing</p>
      <h1>Service Pricing for Austin, Manor, and Houston</h1>

      <p class="lead">
        Clear starting prices for managed VPN, private cloud, network
        monitoring, business Wi‑Fi, backup internet, and restaurant technology
        services.
      </p>

      <p class="service-note">
        <%= pricingData.intro %>
      </p>

      <section class="pricing-anchor-grid" aria-label="Pricing summary">
        <% pricingData.categories.forEach(function(category) { %>
          <a href="#<%= category.slug %>" class="price-anchor-card">
            <span><%= category.title %></span>
            <strong><%= pricingData.anchorMap[category.slug] %></strong>
          </a>
        <% }); %>
      </section>

      <section class="pricing-section">
        <h2>ReadyTech Rate Card</h2>
        <p>
          Hourly and project rates for support, network work, vendor
          coordination, and emergency response.
        </p>

        <div class="table-wrap">
          <table class="pricing-table detail-pricing-table">
            <thead>
              <tr>
                <th>Service Type</th>
                <th>Suggested Rate</th>
              </tr>
            </thead>
            <tbody>
              <% pricingData.rateCard.forEach(function(row) { %>
                <tr>
                  <td><%= row.service %></td>
                  <td><%= row.rate %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>

      <% pricingData.categories.forEach(function(category) { %>
        <section id="<%= category.slug %>" class="pricing-section category-pricing-section">
          <div class="pricing-section-heading">
            <div>
              <p class="eyebrow">Service Category</p>
              <h2><%= category.title %></h2>
              <p><%= category.description %></p>
            </div>

            <div class="category-anchor-price">
              <span>Starting at</span>
              <strong><%= pricingData.anchorMap[category.slug] %></strong>
            </div>
          </div>

          <div class="table-wrap">
            <table class="pricing-table detail-pricing-table">
              <thead>
                <tr>
                  <th>Service</th>
                  <th>Setup / Project</th>
                  <th>Monthly / Rate</th>
                </tr>
              </thead>
              <tbody>
                <% category.plans.forEach(function(plan) { %>
                  <tr>
                    <td><%= plan.service %></td>
                    <td><%= plan.setup %></td>
                    <td><%= plan.monthly %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <% const includePlans = category.plans.filter(function(plan) { return plan.includes && plan.includes.length; }); %>
          <% if (includePlans.length) { %>
            <div class="plan-includes-grid">
              <% includePlans.forEach(function(plan) { %>
                <article class="card compact-card">
                  <h3><%= plan.service %></h3>
                  <ul>
                    <% plan.includes.forEach(function(item) { %>
                      <li><%= item %></li>
                    <% }); %>
                  </ul>
                </article>
              <% }); %>
            </div>
          <% } %>

          <% if (category.notes && category.notes.length) { %>
            <div class="pricing-notes">
              <% category.notes.forEach(function(note) { %>
                <p><%= note %></p>
              <% }); %>
            </div>
          <% } %>
        </section>
      <% }); %>

      <section class="pricing-section pricing-rules">
        <h2>Pricing Notes</h2>
        <ul>
          <% pricingData.rules.forEach(function(rule) { %>
            <li><%= rule %></li>
          <% }); %>
        </ul>
      </section>

      <section class="card featured-panel pricing-cta">
        <h2>Need a custom quote?</h2>
        <p>
          Tell ReadyTech what you are trying to connect, monitor, secure, or
          support. We can recommend the right service level for your site.
        </p>
        <a href="/contact" class="button">Request a Quote</a>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
