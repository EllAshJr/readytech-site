<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="container section">
      <h1>Private Infrastructure Pricing</h1>
      <p>
        Simple recurring service pricing for secure networking, VPN, private
        cloud, monitoring, Wi-Fi, and backup internet.
      </p>

      <div class="pricing-grid">
        <article class="price-card">
          <h2>Home Secure Network</h2>
          <p class="price">$49/mo</p>
          <ul>
            <li>Managed home network</li>
            <li>Basic VPN support</li>
            <li>Wi-Fi support</li>
            <li>Monthly health check</li>
          </ul>
        </article>

        <article class="price-card featured">
          <h2>Small Business Infrastructure</h2>
          <p class="price">$149/mo</p>
          <ul>
            <li>Managed secure network</li>
            <li>Managed VPN</li>
            <li>Monitoring</li>
            <li>Basic security support</li>
          </ul>
        </article>

        <article class="price-card">
          <h2>Business Continuity</h2>
          <p class="price">$249/mo</p>
          <ul>
            <li>Network management</li>
            <li>Dual internet support</li>
            <li>LTE/5G failover</li>
            <li>Uptime monitoring</li>
          </ul>
        </article>

        <article class="price-card">
          <h2>Private Infrastructure</h2>
          <p class="price">$399/mo</p>
          <ul>
            <li>Managed network</li>
            <li>Private cloud</li>
            <li>VPN</li>
            <li>Backups</li>
            <li>Monitoring</li>
          </ul>
        </article>
      </div>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
