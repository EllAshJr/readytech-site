# Local development template only. Never commit a real .env file.

# Core app
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database
# Local WSL PostgreSQL can use:
# DATABASE_URL=postgresql://readytech:readytechdev@localhost:5432/readytech_dev
#
# Render production should use the Render internal PostgreSQL DATABASE_URL.
# Use DATABASE_SSL=false for local PostgreSQL and Render internal databases.
# Use DATABASE_SSL=true only when connecting locally to a Render external database URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=false
DATABASE_POOL_MAX=5

# Email / Resend
RESEND_API_KEY=re_replace_me
OWNER_EMAIL=owner@example.com
QUOTE_FROM_EMAIL=ReadyTech Estimates <quotes@updates.readytechinstalls.com>
QUOTE_REPLY_TO=contact@readytechinstalls.com

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me
TURNSTILE_EXPECTED_HOSTNAME=readytechinstalls.com

# Instant Estimate
QUOTE_TOKEN_SECRET=replace_with_at_least_32_random_bytes

# Sales Coach
# Local development shared-login defaults are sales / readytech when these are omitted.
# In production, keep the shared login only as an owner/admin fallback.
SALES_APP_USERNAME=sales
SALES_APP_PASSWORD=readytech
SALES_SESSION_SECRET=replace-with-openssl-rand-hex-32
SALES_SESSION_HOURS=8

# One-time Sales Coach account links.
# Invites are generated per salesperson and stored as token hashes in PostgreSQL.
SALES_INVITE_EXPIRES_HOURS=168
SALES_PASSWORD_RESET_EXPIRES_MINUTES=60
SALES_ACCOUNT_FROM_EMAIL=ReadyTech Sales Coach <sales@updates.readytechinstalls.com>

# Email the completed plan to the salesperson who logged in.
# Production should also set SALES_OWNER_COPY_EMAIL or OWNER_EMAIL for owner copies.
# SALES_OWNER_COPY_EMAIL can be one email or a comma-separated list.
SALES_REPORT_FROM_EMAIL=ReadyTech Sales Coach <sales@updates.readytechinstalls.com>
SALES_OWNER_COPY_EMAIL=owner@example.com

# Deployment
# Render should set production values in the service environment.
# Do not commit real .env files, credentials, API keys, database URLs, tokens, or backups.
