<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>

  <body>
    <%- include("partials/header") %>

    <main class="restaurant-page">
      <%
        const readyContinuityPro = siteStrategy.flagshipOffers.find(
          function (offer) {
            return offer.id === "readycontinuity-pro";
          }
        );

        if (!readyContinuityPro) {
          throw new Error("ReadyContinuity Pro offer is missing.");
        }
      %>

      <section class="hero">
        <div class="container">
          <p class="eyebrow">ReadyOps for Restaurants</p>

          <h1>Restaurant Network, POS & Uptime Support</h1>

          <p>
            Restaurants are ReadyTech’s first specialization—not its only
            market. We help restaurant operators keep POS, payments, Wi-Fi,
            online orders, printers, kitchen systems, and internet connectivity
            operating reliably.
          </p>

          <div class="hero-actions">
            <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
              Book a Business Uptime Assessment
            </a>

            <a
              href="/instant-quote?service=restaurant-technology"
              class="button secondary"
            >
              Get a Restaurant Estimate
            </a>

            <a
              href="/ready-kitchen-exhaust"
              class="button secondary"
              data-track-lead="restaurant-kitchen-exhaust"
            >
              Need Kitchen Exhaust Maintenance?
            </a>
          </div>
        </div>
      </section>

      <section class="container section">
        <article class="card featured-panel">
          <p class="eyebrow">Managed restaurant operations</p>

          <h2><%= siteStrategy.restaurantAddOn.title %></h2>

          <p class="price"><%= siteStrategy.restaurantAddOn.price %></p>

          <p><%= siteStrategy.restaurantAddOn.description %></p>

          <ul>
            <% siteStrategy.restaurantAddOn.includes.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <p>
            <strong><%= siteStrategy.restaurantAddOn.typicalTotal %></strong>
          </p>
        </article>
      </section>

      <section class="container section">
        <h2>Core Restaurant Infrastructure</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.coreServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>POS, Menus & Delivery Operations</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.operationsServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Customer Experience & Retention</h2>

        <div
          class="grid restaurant-wide-grid restaurant-no-scroll-grid customer-experience-grid"
        >
          <% restaurantData.customerExperienceServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Includes</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Restaurant Monitoring</h2>

        <div class="grid restaurant-wide-grid restaurant-no-scroll-grid">
          <% restaurantData.monitoringServices.forEach(function(service) { %>
            <article class="card service-card">
              <h3><%= service.name %></h3>
              <p><%= service.description %></p>

              <h4>Monitored Items</h4>

              <ul>
                <% service.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>

              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Setup / Price</th>
                    <th>Monthly</th>
                  </tr>
                </thead>

                <tbody>
                  <% service.pricing.forEach(function(row) { %>
                    <tr>
                      <td><%= row.service %></td>
                      <td><%= row.setup %></td>
                      <td><%= row.monthly %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </article>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <h2>Restaurant Technology Packages</h2>

        <div class="pricing-grid">
          <% restaurantData.packages.forEach(function(pkg) { %>
            <article class="price-card">
              <h3><%= pkg.name %></h3>

              <p><%= pkg.description %></p>

              <p>
                <strong>Setup:</strong>
                <%= pkg.setup %>
              </p>

              <p>
                <strong>Monthly:</strong>
                <%= pkg.monthly %>
              </p>

              <ul>
                <% pkg.includes.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>
            </article>
          <% }); %>
        </div>
      </section>

            <section id="restaurant-continuity" class="container section">
        <article class="card featured-panel flagship-featured">
          <p class="eyebrow">Recommended restaurant continuity plan</p>

          <h2><%= readyContinuityPro.title %></h2>

          <p class="price"><%= readyContinuityPro.price %></p>

          <p><%= readyContinuityPro.priceNote %></p>

          <p><%= readyContinuityPro.description %></p>

          <ul>
            <% readyContinuityPro.includes.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>

          <div class="hero-actions">
            <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
              Book a Business Uptime Assessment
            </a>

            <a
              href="/instant-quote?service=restaurant-technology"
              class="button secondary"
            >
              Get a Restaurant Estimate
            </a>
          </div>
        </article>
      </section>

      <section class="container section">
        <h2>Restaurant Service Pages</h2>

        <p>
          Explore specific restaurant connectivity and operations services
          available for businesses in Austin, Manor, and Houston.
        </p>

        <div class="link-grid">
          <% Object.keys(restaurantData.seoServices).forEach(function(slug) { %>
            <a href="/services/<%= slug %>" class="mini-link">
              <%= restaurantData.seoServices[slug].title %>
            </a>
          <% }); %>
        </div>
      </section>

      <section class="container section">
        <p class="service-note"><%= siteStrategy.pricingNotice %></p>

        <div class="hero-actions">
          <a href="<%= siteStrategy.ctas.primary.href %>" class="button">
            Book a Business Uptime Assessment
          </a>

          <a
            href="/instant-quote?service=restaurant-technology"
            class="button secondary"
          >
            Get an Instant Estimate
          </a>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
